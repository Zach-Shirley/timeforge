# Copy this file to .env and adjust values for your local machine.
# Do not commit .env, Google OAuth credentials, tokens, or SQLite data.

TIME_OUTPUT_TIMEZONE=America/Denver
TIME_OUTPUT_TRACKING_START_DATE=2026-01-01
TIME_OUTPUT_CALENDAR_START=2026-01-01T00:00:00
TIME_OUTPUT_DAY_START_HOUR=5

TIME_OUTPUT_DATA_DIR=Data
TIME_OUTPUT_DB_PATH=Data/time_tracking.sqlite
TIME_OUTPUT_STATIC_DATA_PATH=Dashboard/data/app-data.json
TIME_OUTPUT_SERVE_STATIC_EXPORT=0

TIME_OUTPUT_GOOGLE_CALENDAR_ID=primary
TIME_OUTPUT_GOOGLE_CREDENTIALS_PATH=Data/google_credentials.json
TIME_OUTPUT_GOOGLE_TOKEN_PATH=Data/google_token.json
